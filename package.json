{
  "name": "aegis-forge",
  "version": "1.1.0",
  "description": "Ultra-lightweight zero-dependency browser-native video editing engine",
  "main": "dist/AegisForge.min.js",
  "scripts": {
    "build": "node build-worker.js && esbuild src/index.ts --bundle --minify --format=iife --global-name=AegisForge --outfile=dist/AegisForge.min.js",
    "dev": "node build-worker.js && esbuild src/index.ts --bundle --format=iife --global-name=AegisForge --outfile=dist/AegisForge.js --watch",
    "builder": "npx serve ."
  },
  "keywords": [
    "video",
    "editor",
    "webcodecs",
    "webgpu",
    "webgl",
    "nle",
    "transcoder",
    "browser",
    "gpu"
  ],
  "license": "WTFPL",
  "devDependencies": {
    "@webgpu/types": "^0.1.69",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0"
  }
}